<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PyRebuilderSharp.Gui.ViewModels"
        x:Class="PyRebuilderSharp.Gui.Views.MainWindow"
        Title="PyRebuilderSharp - Python字节码反编译器"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto, *, Auto">
    <Border Background="#323233" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6">
        <Button Command="{Binding OpenFileCommand}" Padding="8,4" Background="#0e639c"
                BorderThickness="0" Foreground="#fff" CornerRadius="2" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="📂" /><TextBlock Text="打开" /></StackPanel>
        </Button>
        <Button Command="{Binding SaveResultCommand}" Padding="8,4" Background="#2d2d2d"
                BorderBrush="#3c3c3c" Foreground="#ccc" BorderThickness="1" CornerRadius="2" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="💾" /><TextBlock Text="保存" /></StackPanel>
        </Button>
        <Button Command="{Binding DecompileCommand}" Padding="8,4" Background="#2d2d2d"
                BorderBrush="#3c3c3c" Foreground="#ccc" BorderThickness="1"
                CornerRadius="2" IsVisible="{Binding HasFile}" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="▶" /><TextBlock Text="反编译" /></StackPanel>
        </Button>
        <Separator Width="1" Background="#3c3c3c" Margin="6,2" />
        <TextBlock Text="{Binding PythonVersion}" VerticalAlignment="Center" FontSize="12" Foreground="#999" />
        <TextBlock Text="{Binding StatsText}" VerticalAlignment="Center" FontSize="12" Foreground="#999" Margin="8,0,0,0" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280, 4, *">
      <!-- 文件树 -->
      <Border Background="#252526" BorderThickness="0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="📂 字节码文件" FontWeight="SemiBold" Margin="12,10" Foreground="#bbb" FontSize="12" />
          <ScrollViewer Background="Transparent">
            <TreeView ItemsSource="{Binding FileTree}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                      BorderThickness="0" Background="Transparent">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                  <Border Margin="2,1" Padding="6,4" CornerRadius="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Icon}" FontSize="13" />
                      <TextBlock Text="{Binding Name}" Foreground="#ccc" FontSize="12" />
                    </StackPanel>
                  </Border>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1" Width="4" Background="#252526" />

      <!-- 右侧双栏 -->
      <Grid Grid.Column="2" ColumnDefinitions="*, 4, *" Background="#1e1e1e">
        <!-- 左：字节码 -->
        <Border BorderThickness="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#2d2d2d" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="10,5">
              <TextBlock Text="🔍 字节码 (dis)" Foreground="#bbb" FontSize="11" />
            </Border>
            <ScrollViewer Background="#1e1e1e" HorizontalScrollBarVisibility="Auto">
              <SelectableTextBlock x:Name="DisasmBlock"
                FontFamily="Consolas,Menlo,Monaco,'Courier New',monospace"
                FontSize="12" Foreground="#d4d4d4" LineHeight="18"
                TextWrapping="NoWrap" Margin="8,4" />
            </ScrollViewer>
          </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" Background="#2d2d2d" />

        <!-- 右：Python 源码 -->
        <Border Grid.Column="2" BorderThickness="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#2d2d2d" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="10,5">
              <TextBlock Text="{Binding CurrentFileName}" Foreground="#bbb" FontSize="11" />
            </Border>
            <ScrollViewer Background="#1e1e1e" HorizontalScrollBarVisibility="Auto">
              <SelectableTextBlock x:Name="SourceBlock"
                FontFamily="Consolas,Menlo,Monaco,'Courier New',monospace"
                FontSize="13" Foreground="#d4d4d4" LineHeight="20"
                TextWrapping="NoWrap" Margin="8,4" />
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- 状态栏 -->
    <Border Grid.Row="2" Background="#007acc" BorderThickness="0">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,3">
          <TextBlock Text="{Binding StatusText}" Foreground="#fff" FontSize="12" />
        </StackPanel>
        <ProgressBar Grid.Column="1" IsVisible="{Binding IsDecompiling}" IsIndeterminate="True"
                     Width="80" Height="12" Margin="8,2" Foreground="#4ec9b0" Background="#005a9e" />
      </Grid>
    </Border>
  </Grid>
</Window>
