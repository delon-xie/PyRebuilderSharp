<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PyRebuilderSharp.Gui.ViewModels"
        x:Class="PyRebuilderSharp.Gui.Views.MainWindow"
        Title="PyRebuilderSharp - Python字节码反编译器"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen">

  <Grid RowDefinitions="Auto, *, Auto, Auto">
    <Border Background="#323233" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6">
        <Button Command="{Binding OpenFileCommand}" Padding="8,4" Background="#0e639c"
                BorderThickness="0" Foreground="#fff" CornerRadius="2" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="📂" /><TextBlock Text="打开" /></StackPanel>
        </Button>
        <Button Command="{Binding SaveResultCommand}" Padding="8,4" Background="#2d2d2d"
                BorderBrush="#3c3c3c" Foreground="#ccc" BorderThickness="1" CornerRadius="2" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="💾" /><TextBlock Text="保存" /></StackPanel>
        </Button>
        <Button Command="{Binding DecompileCommand}" Padding="8,4" Background="#2d2d2d"
                BorderBrush="#3c3c3c" Foreground="#ccc" BorderThickness="1"
                CornerRadius="2" IsVisible="{Binding HasFile}" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="▶" /><TextBlock Text="反编译" /></StackPanel>
        </Button>
        <Button Command="{Binding ShowCrashLogCommand}" Padding="8,4" Background="#2d2d2d"
                BorderBrush="#3c3c3c" Foreground="#ccc" BorderThickness="1"
                CornerRadius="2" Cursor="Hand">
          <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="📋" /><TextBlock Text="崩溃日志" /></StackPanel>
        </Button>
        <Separator Width="1" Background="#3c3c3c" Margin="6,2" />
        <TextBlock Text="{Binding PythonVersion}" VerticalAlignment="Center" FontSize="12" Foreground="#999" />
        <TextBlock Text="{Binding StatsText}" VerticalAlignment="Center" FontSize="12" Foreground="#999" Margin="8,0,0,0" />
        <Separator Width="1" Background="#3c3c3c" Margin="6,2" />
        <CheckBox IsChecked="{Binding ShowOrphanBlocks}" Content="孤儿块" 
                  VerticalAlignment="Center" FontSize="11" Foreground="#bbb"
                  Background="Transparent" BorderBrush="#555" />
        <CheckBox IsChecked="{Binding ShowSummary}" Content="#summary" 
                  VerticalAlignment="Center" FontSize="11" Foreground="#bbb"
                  Background="Transparent" BorderBrush="#555" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="280, 4, *">
      <!-- 文件树 -->
      <Border x:Name="FileTreeBorder" Background="{Binding DropHighlightBackground}" BorderThickness="0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="📂 字节码文件" FontWeight="SemiBold" Margin="12,10" Foreground="#bbb" FontSize="12" />
          <ScrollViewer Background="Transparent">
            <TreeView ItemsSource="{Binding FileTree}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                      BorderThickness="0" Background="Transparent">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                  <Border Margin="2,1" Padding="6,4" CornerRadius="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding Icon}" FontSize="13" />
                      <TextBlock Text="{Binding Name}" Foreground="#ccc" FontSize="12" />
                    </StackPanel>
                  </Border>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1" Width="4" Background="#252526" />

      <!-- 右侧双栏 -->
      <Grid Grid.Column="2" ColumnDefinitions="*, 4, *" Background="#1e1e1e">
        <!-- 左：字节码 -->
        <Border BorderThickness="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#2d2d2d" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="10,5">
              <TextBlock Text="🔍 字节码 (dis)" Foreground="#bbb" FontSize="11" />
            </Border>
            <ScrollViewer x:Name="DisasmScroll" Background="#1e1e1e" HorizontalScrollBarVisibility="Auto">
              <SelectableTextBlock x:Name="DisasmBlock"
                FontFamily="Consolas,Menlo,Monaco,'Courier New',monospace"
                FontSize="12" Foreground="#d4d4d4" LineHeight="18"
                TextWrapping="NoWrap" Margin="8,4" />
            </ScrollViewer>
          </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" Background="#2d2d2d" />

        <!-- 右：Python 源码 -->
        <Border Grid.Column="2" BorderThickness="0">
          <DockPanel>
            <Border DockPanel.Dock="Top" Background="#2d2d2d" BorderBrush="#3c3c3c" BorderThickness="0,0,0,1" Padding="10,5">
              <TextBlock Text="{Binding CurrentFileName}" Foreground="#bbb" FontSize="11" />
            </Border>
            <ScrollViewer x:Name="SourceScroll" Background="#1e1e1e" HorizontalScrollBarVisibility="Auto">
              <SelectableTextBlock x:Name="SourceBlock"
                FontFamily="Consolas,Menlo,Monaco,'Courier New',monospace"
                FontSize="13" Foreground="#d4d4d4" LineHeight="20"
                TextWrapping="NoWrap" Margin="8,4" />
            </ScrollViewer>
          </DockPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- 崩溃日志面板 -->
    <Border Grid.Row="2" Background="#1e1e1e" BorderThickness="0" IsVisible="{Binding ShowCrashLog}">
      <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2d2d2d" BorderBrush="#3c3c3c" BorderThickness="0,1,0,1" Padding="10,4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="📋 崩溃日志" Foreground="#bbb" FontSize="11" FontWeight="SemiBold" />
            <TextBlock Text="{Binding CrashCountText}" Foreground="#888" FontSize="11" />
            <Button Content="🗑 清除" Command="{Binding ClearCrashLogCommand}" Padding="8,2" Background="#3c3c3c" BorderThickness="0" Foreground="#ccc" FontSize="10" CornerRadius="2" Cursor="Hand" />
            <Button Content="✕ 关闭" Command="{Binding CloseCrashLogCommand}" Padding="8,2" Background="#3c3c3c" BorderThickness="0" Foreground="#ccc" FontSize="10" CornerRadius="2" Cursor="Hand" />
          </StackPanel>
        </Border>
        <ScrollViewer Background="#1e1e1e" MaxHeight="200">
          <ItemsControl ItemsSource="{Binding CrashEntries}" BorderThickness="0" Background="Transparent">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Margin="8,2" Padding="8,4" Background="#2d2d2d" CornerRadius="3" BorderBrush="#3c3c3c" BorderThickness="1">
                  <Grid ColumnDefinitions="Auto, *">
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="0,0,12,0">
                      <TextBlock Text="{Binding Timestamp, StringFormat='{}{yyyy-MM-dd HH:mm:ss}'}" Foreground="#999" FontSize="10" />
                      <TextBlock Text="{Binding ExceptionType}" Foreground="#f48771" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
                      <TextBlock Text="{Binding FileName}" Foreground="#ce9178" FontSize="11" />
                      <TextBlock Text="{Binding ExceptionMessage}" Foreground="#d4d4d4" FontSize="11" TextWrapping="NoWrap" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- 状态栏 -->
    <Border Grid.Row="3" Background="#007acc" BorderThickness="0">
      <Grid ColumnDefinitions="*, Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="10,3">
          <TextBlock Text="{Binding StatusText}" Foreground="#fff" FontSize="12" />
        </StackPanel>
        <ProgressBar Grid.Column="1" IsVisible="{Binding IsDecompiling}" IsIndeterminate="True"
                     Width="80" Height="12" Margin="8,2" Foreground="#4ec9b0" Background="#005a9e" />
      </Grid>
    </Border>
  </Grid>
</Window>
